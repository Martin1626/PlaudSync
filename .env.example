# Copy to .env (which is gitignored) and fill real values.
# NEVER commit .env.

# Plaud API — obtain from Plaud Developer Platform
PLAUD_API_TOKEN=

# Microsoft Graph (M365) — app registration in Entra ID
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# Anthropic API — for LLM classifier fallback
ANTHROPIC_API_KEY=

# Sentry — free tier, project "plaudsync"
# If empty, Sentry init is skipped (log-file-only mode)
SENTRY_DSN=

# Local storage root for downloaded recordings
# Example: C:\PlaudRecordings
PLAUDSYNC_LOCAL_ROOT=

# Environment label (dev / prod) — tag on Sentry events
PLAUDSYNC_ENV=dev
