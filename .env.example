# Copy to .env (which is gitignored) and fill real values.
# NEVER commit .env.

# Plaud API — manual paste from browser localStorage.tokenstr
# (Plaud Developer Platform is B2B-only as of 2026-04-24; manual paste workflow.)
PLAUD_API_TOKEN=

# Sentry — free tier, project "plaudsync"
# If empty, Sentry init is skipped (log-file-only mode)
SENTRY_DSN=

# State root — absolute path to a directory containing PlaudSync state ONLY
# (config.yaml + .plaudsync/state.db + .plaudsync/sync.lock + plaudsync.log).
# Recordings live on per-project absolute paths defined inside config.yaml.
# Example: C:\PlaudSync
PLAUDSYNC_STATE_ROOT=

# Environment label (dev / prod) — tag on Sentry events
PLAUDSYNC_ENV=dev

# Override trigger label for audit; UI subprocess sets ui_sync_now,
# manual terminal run can set "manual". Default: task_scheduler.
# PLAUDSYNC_TRIGGER=manual

# Optional: enable PyWebView DevTools (F12) by setting to "1"
# PLAUDSYNC_UI_DEBUG=1

# Dev mode (--dev flag): port uvicorn binds while Vite proxies /api/* to it.
# Default 8765 if unset.
# PLAUDSYNC_DEV_PORT=8765
